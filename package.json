{
  "name": "valorar-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "verify:workspace": "node scripts/verify-workspace-scripts.mjs",
    "predev": "npm run verify:workspace",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
