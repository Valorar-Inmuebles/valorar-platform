{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "TENANT_ID",
    "NEXT_PUBLIC_SITE_URL",
    "PUBLIC_COMPANY_NAME",
    "PUBLIC_SITE_DESCRIPTION",
    "PUBLIC_WHATSAPP",
    "PUBLIC_EMAIL",
    "PUBLIC_PHONE",
    "PUBLIC_ADDRESS",
    "PUBLIC_PRIMARY_COLOR",
    "PUBLIC_SECONDARY_COLOR",
    "PUBLIC_FACEBOOK_URL",
    "PUBLIC_INSTAGRAM_URL",
    "PUBLIC_LINKEDIN_URL",
    "API_URL",
    "PUBLIC_WEB_URL",
    "PORT",
    "DATABASE_URL",
    "ADMIN_DEV_TENANT_ID",
    "ADMIN_DEV_USER_ID",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
