# Server
PORT=3002

# PostgreSQL connection string (required — api will fail to start without it)
DATABASE_URL=

# Auth (required — api will fail to start without JWT_SECRET)
JWT_SECRET=
JWT_EXPIRES_IN=8h

# CORS origin for admin app (credentials: true)
CORS_ORIGIN=http://localhost:3001

# Cookie security (set false for local HTTP dev)
COOKIE_SECURE=false

# Optional cookie max age override in milliseconds
# COOKIE_MAX_AGE_MS=28800000

# Dev seed only — required to run `npx prisma db seed` (never use in production)
SEED_DEFAULT_PASSWORD=
