# Server
PORT=3002

# PostgreSQL connection string (required — api will fail to start without it)
DATABASE_URL=

# Auth (required — api will fail to start without JWT_SECRET)
JWT_SECRET=
JWT_EXPIRES_IN=8h

# CORS origin for admin app (credentials: true)
CORS_ORIGIN=http://localhost:3001

# Cookie security (set false for local HTTP dev)
COOKIE_SECURE=false

# Optional cookie max age override in milliseconds
# COOKIE_MAX_AGE_MS=28800000

# Public web base URL for admin «Ver en web» links in publishability summary
PUBLIC_WEB_URL=http://localhost:3000

# Dev seed only — required to run `npx prisma db seed` (never use in production)
SEED_DEFAULT_PASSWORD=

# Dev seed opt-in — load 30 demo properties for public web validation
# SEED_DEMO_PROPERTIES=true

# Dev seed opt-in — load Argentina geo catalog (provinces, localities, CABA neighborhoods)
# SEED_GEO_CATALOG=true

# Object storage (S3-compatible — Cloudflare R2, AWS S3, etc.)
# Required for property image uploads
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=
STORAGE_PUBLIC_URL=
# Optional — defaults to "auto" (recommended for Cloudflare R2)
# STORAGE_REGION=auto
